# Copy this file to .env and fill in your actual values.
# .env is gitignored and must NEVER be committed.

# Database name
TW_DB=ticketwizard

# Database credentials (must match the values used to initialize the Docker container)
TW_USER=postgres
TW_PASSWORD=your_password_here

# Spring Boot datasource URL (used when running locally via ./mvnw spring-boot:run)
DB_URL=jdbc:postgresql://localhost:5433/ticketwizard
